{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2020",
		"outDir": "out",
		"lib": [
			"ES2020"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"types": ["node", "vscode"]
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"resources",
		"out",
		"node_modules"
	]
}