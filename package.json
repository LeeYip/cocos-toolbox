{
  "name": "cocos-toolbox",
  "displayName": "Cocos Toolbox",
  "description": "Enhance your Cocos Creator project development workflow.",
  "version": "1.0.7",
  "publisher": "lee-yip",
  "icon": "image/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeeYip/cocos-toolbox"
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "CocosToolbox.findReferences",
        "title": "Find Cocos References",
        "category": "Cocos"
      },
      {
        "command": "CocosToolbox.showAssetInCreator",
        "title": "Show in Cocos Creator",
        "category": "Cocos"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "CocosToolbox.findReferences",
          "group": "navigation",
          "when": "CocosToolbox.isCocosProject && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && (editorLangId == typescript || editorLangId == javascript)"
        },
        {
          "command": "CocosToolbox.showAssetInCreator",
          "group": "navigation",
          "when": "CocosToolbox.isCocosProject && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && resourceExtname =~ /\\.(png|jpg|jpeg|webp|bmp|gif|svg|fbx|prefab|anim|animation|fire|scene|atlas|plist|json|material|mtl|effect|shader|mp3|wav|ogg|m4a|mp4|ttf|otf|fnt)$/i"
        }
      ],
      "explorer/context": [
        {
          "command": "CocosToolbox.findReferences",
          "group": "navigation",
          "when": "CocosToolbox.isCocosProject && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && resourceExtname =~ /\\.(ts|js)$/i"
        },
        {
          "command": "CocosToolbox.showAssetInCreator",
          "group": "navigation",
          "when": "CocosToolbox.isCocosProject && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && resourceExtname =~ /\\.(png|jpg|jpeg|webp|bmp|gif|svg|fbx|prefab|anim|animation|fire|scene|atlas|plist|json|material|mtl|effect|shader|mp3|wav|ogg|m4a|mp4|ttf|otf|fnt)$/i"
        }
      ]
    },
    "keybindings": [
      {
        "command": "CocosToolbox.findReferences",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "CocosToolbox.isCocosProject && editorTextFocus && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && (editorLangId == typescript || editorLangId == javascript)"
      },
      {
        "command": "CocosToolbox.showAssetInCreator",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o",
        "when": "CocosToolbox.isCocosProject && editorTextFocus && resourceDirname =~ /[\\\\/]assets([\\\\/]|$)/ && resourceExtname =~ /\\.(png|jpg|jpeg|webp|bmp|gif|svg|fbx|prefab|anim|animation|fire|scene|atlas|plist|json|material|mtl|effect|shader|mp3|wav|ogg|m4a|mp4|ttf|otf|fnt)$/i"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Cocos Toolbox",
      "properties": {
        "CocosToolbox.enableMeta": {
          "type": "boolean",
          "default": true,
          "description": "Enable auto sync meta file"
        },
        "CocosToolbox.enableColor": {
          "type": "boolean",
          "default": true,
          "description": "Enable show color token"
        },
        "CocosToolbox.colorLanguages": {
          "type": "array",
          "default": [
            "javascript",
            "typescript",
            "json"
          ],
          "items": {
            "type": "string"
          },
          "description": "List of file formats supported by color token."
        },
        "CocosToolbox.creatorBridgeRequestTimeout": {
          "type": "number",
          "default": 3000,
          "minimum": 200,
          "description": "Timeout (milliseconds) for requests to the Cocos Creator bridge."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:bridge && npm run compile",
    "build:bridge": "npm --prefix ./resources/vscode-creator-bridge run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.50.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0"
  }
}